        </div>
      </a>
      <div class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-5">
        <div class="w-10 h-10 rounded-lg bg-gov-blue-light flex items-center justify-center flex-shrink-0">
          <svg aria-hidden="true" class="w-5 h-5 text-gov-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/></svg>
        </div>
        <div>
          <div class="text-sm font-bold text-navy">Aberdeen Fire</div>
          <div class="text-xs text-slate-500">Emergency: 911</div>
        </div>
      </div>
      <a href="https://www.harfordcountymd.gov/government/departments/emergency-services" class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-5 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
        <div class="w-10 h-10 rounded-lg bg-gov-blue-light flex items-center justify-center group-hover:bg-gov-blue transition-colors duration-200 flex-shrink-0">
          <svg aria-hidden="true" class="w-5 h-5 text-gov-blue group-hover:text-white transition-colors duration-200" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
        </div>
        <div>
          <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">Harford County EMS</div>
          <div class="text-xs text-slate-500">Emergency: 911</div>
        </div>
      </a>
    </div>
  </div>

  <div class="bg-gov-blue-light rounded-xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div>
      <h2 class="text-lg font-bold text-navy mb-1">Visitor's Guide</h2>
      <p class="text-sm text-slate-600">Download the official City of Aberdeen Visitor's Guide for maps, attractions, and local resources.</p>
    </div>
    <a href="https://www.aberdeenmd.gov/home/files/visitors-guide-0" class="flex-shrink-0 inline-flex items-center gap-2 bg-gov-blue text-white font-semibold px-5 py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200 text-sm whitespace-nowrap">Download Visitor's Guide</a>
  </div>

</div>
