          <dd><a href="tel:+14102722121" class="text-gov-blue hover:underline font-semibold">(410) 272-2121</a></dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">City Hall</dt>
          <dd><a href="tel:+14102721600" class="text-gov-blue hover:underline">(410) 272-1600</a></dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Report Issue (DPW)</dt>
          <dd><a href="mailto:dpw@aberdeenmd.gov" class="text-gov-blue hover:underline text-xs">dpw@aberdeenmd.gov</a></dd>
        </div>
      </dl>
      <div class="pt-2 space-y-2">
        <a href="{{ '/services/report-issue/' | url }}" class="block w-full text-center bg-gov-blue text-white text-sm font-semibold py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200">Report an Issue</a>
        <a href="{{ '/newsletter/' | url }}" class="block w-full text-center border border-slate-200 text-slate-700 text-sm font-semibold py-2.5 rounded hover:border-gov-blue hover:text-gov-blue transition-colors duration-200">City Newsletter</a>
