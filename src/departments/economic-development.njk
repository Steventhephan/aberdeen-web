      <div class="flex items-start gap-4 bg-white border border-slate-200 rounded-xl p-5">
        <div class="w-9 h-9 rounded-lg bg-gov-blue-light flex items-center justify-center flex-shrink-0">
          <svg aria-hidden="true" class="w-5 h-5 text-gov-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="{{ fact.icon }}" clip-rule="evenodd"/></svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-navy mb-1">{{ fact.title }}</h3>
          <p class="text-sm text-slate-600">{{ fact.desc }}</p>
