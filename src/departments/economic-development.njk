  <div class="bg-navy rounded-xl p-6 text-white">
    <h2 class="text-lg font-bold mb-2">Ready to Do Business in Aberdeen?</h2>
    <p class="text-slate-300 text-sm mb-5">Contact our Economic Development office to learn about incentives, site selection assistance, and how Aberdeen can work with your business.</p>
    <a href="{{ '/contact/' | url }}" class="inline-flex items-center gap-2 bg-gov-blue text-white font-semibold px-5 py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200 text-sm">Contact Economic Development</a>
  </div>
</div>
