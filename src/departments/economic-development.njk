        { title: "Prime Location", desc: "Minutes from Baltimore, DC, Wilmington, and Philadelphia via I-95 and MARC Rail.", icon: "M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" },
        { title: "Aberdeen Proving Ground", desc: "Home of the US Army's foremost technology and research center.", icon: "M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4z" },
        { title: "World-Class Schools", desc: "Harford County Public Schools ranked among Maryland's best.", icon: "M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.214l4-1.5a1 1 0 11.713 1.864L8.11 8.84l2.48-1.858A1 1 0 0111 6h1v.697l-2.5 1.875a1 1 0 00-.5.866v4a1 1 0 001.5.866L14 11.43V10a1 1 0 012 0v4a1 1 0 01-1 1H5a1 1 0 01-1-1V8.618l6 2.25V6z" },
        { title: "Business Incentives", desc: "State and local programs available for qualifying businesses.", icon: "M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267zm4-4.849a7 7 0 11-14 0 7 7 0 0114 0z" },
        { title: "Transit Access", desc: "MARC commuter rail station in downtown Aberdeen.", icon: "M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H14a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7h1a2 2 0 012 2v3a2 2 0 01-2 2h-1V7z" },
