      {% endfor %}
    </div>
  </div>

  <div>
    <h2 class="text-2xl font-bold text-navy mb-5">Quick Links</h2>
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
      {% for link in [
        { label: "Business Incentives & Funding", url: "/businesses/incentives/" },
        { label: "How to Apply for a Permit", url: "/services/permits/" },
