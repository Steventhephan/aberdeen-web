<div class="space-y-10">
  <div>
    <p class="text-slate-600 leading-relaxed mb-5">The Finance Department manages the City of Aberdeen's financial operations, including budget preparation, tax collection, accounts payable and receivable, payroll, and online payment services.</p>
  </div>

  <div>
    <h2 class="text-xl font-bold text-navy mb-5">Services</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {% for service in [
        { title: "Online Bill Pay", desc: "Pay water, sewer, and property tax bills online 24/7." },
        { title: "Property Taxes", desc: "Current rate: $0.625 per $100 of assessed value. Billed July 1." },
        { title: "City Budget", desc: "Annual budget preparation, adoption, and reporting." },
        { title: "Financial Reporting", desc: "Audits, financial statements, and transparency reports." },
        { title: "Accounts Payable", desc: "Vendor payments and city procurement processing." },
        { title: "Payroll", desc: "City employee payroll and benefits administration." }
      ] %}
      <div class="bg-white border border-slate-200 rounded-xl p-4">
        <h3 class="text-sm font-bold text-navy mb-1">{{ service.title }}</h3>
        <p class="text-xs text-slate-600">{{ service.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="grid sm:grid-cols-2 gap-4">
    <div class="bg-gov-blue-light rounded-xl p-5 text-center">
      <div class="text-3xl font-bold text-navy mb-1">$0.625</div>
      <div class="text-sm text-slate-600">per $100 assessed value</div>
      <div class="text-xs text-slate-500 mt-1">Current property tax rate</div>
    </div>
    <div class="bg-gov-blue-light rounded-xl p-5 text-center">
      <div class="text-3xl font-bold text-navy mb-1">July 1</div>
      <div class="text-sm text-slate-600">Annual tax billing date</div>
      <div class="text-xs text-slate-500 mt-1">Tax bills mailed each year</div>
    </div>
  </div>

  <div>
    <h2 class="text-xl font-bold text-navy mb-5">Quick Links</h2>
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
      {% for link in [
        { label: "Pay Bills Online", url: "/services/pay-bills/" },
        { label: "Property Tax Info", url: "/services/taxes/" },
        { label: "City Budget Documents", url: "/budget/" },
        { label: "Where Does Your Money Go?", url: "https://www.aberdeenmd.gov/finance/files/where-does-your-money-go-fy2026-0" },
        { label: "Bids & RFPs", url: "/businesses/bids/" },
        { label: "Contact Finance", url: "/contact/" }
      ] %}
      <a href="{{ link.url | url }}" class="flex items-center justify-between gap-3 text-sm text-slate-700 font-medium px-5 py-3 hover:text-gov-blue hover:bg-slate-50 transition-colors duration-150 group border-b border-slate-100 last:border-b-0">
        {{ link.label }}
        <svg aria-hidden="true" class="w-4 h-4 text-slate-400 group-hover:text-gov-blue flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
      {% endfor %}
    </div>
  </div>
