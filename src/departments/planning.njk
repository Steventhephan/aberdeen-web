  <div>
    <h2 class="text-2xl font-bold text-navy mb-6">How to Submit a Permit</h2>
    <div class="grid sm:grid-cols-2 gap-5">
      <div class="flex gap-4 bg-white border border-slate-200 rounded-xl p-5">
        <div class="w-10 h-10 rounded-full bg-gov-blue text-white flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5">1</div>
        <div>
          <h3 class="text-base font-bold text-navy mb-2">In-Person Drop-Off</h3>
          <p class="text-sm text-slate-600 leading-relaxed">City Hall lobby Dropbox, 60 N. Parke Street — available Monday–Friday, 8:30 AM–5:00 PM.</p>
        </div>
      </div>
      <div class="flex gap-4 bg-white border border-slate-200 rounded-xl p-5">
        <div class="w-10 h-10 rounded-full bg-gov-blue text-white flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5">2</div>
        <div>
          <h3 class="text-base font-bold text-navy mb-2">Electronic Submission</h3>
          <p class="text-sm text-slate-600 leading-relaxed">Submit permits electronically — call <strong>ext. 221</strong> or stop by the lobby phone to get the current submission email address.</p>
        </div>
      </div>
    </div>
  </div>

