---
layout: department.njk
title: City Clerk
subtitle: Official city records, meeting agendas and minutes, elections, and public information requests.
description: Aberdeen City Clerk — meeting agendas, council minutes, elections, MPIA requests, and official city records. Call (410) 272-1600 ext. 211.
deptPhone: "(410) 272-1600 ext. 211"
deptRealUrl: "https://www.aberdeenmd.gov/city-clerk"
---

<div class="space-y-10">
  <div>
    <p class="text-slate-600 leading-relaxed">The City Clerk serves as the official keeper of City records, manages City Council meeting logistics including agendas and minutes, administers municipal elections, and processes Maryland Public Information Act requests.</p>
  </div>

  <div>
    <h2 class="text-2xl font-bold text-navy mb-5">Services</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {% for service in [
        { title: "Meeting Agendas & Minutes", desc: "All Council and board meeting documents, past and present.", icon: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" },
        { title: "Live Meeting Stream", desc: "Watch City Council meetings live online.", icon: "M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z" },
        { title: "Municipal Elections", desc: "Voter registration, candidate packets, and election results.", icon: "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" },
        { title: "Public Records (MPIA)", desc: "Maryland Public Information Act request processing.", icon: "M9 2a1 1 0 000 2h2a1 1 0 100-2H9zM4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" },
        { title: "Proclamation Requests", desc: "Requests for City proclamations and official recognitions.", icon: "M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6V11.1A4.369 4.369 0 0015 11c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z" },
        { title: "City Charter & Code", desc: "Official City of Aberdeen Charter and Code of Ordinances.", icon: "M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" }
      ] %}
      <div class="flex items-start gap-4 bg-white border border-slate-200 rounded-xl p-5">
        <div class="w-9 h-9 rounded-lg bg-gov-blue-light flex items-center justify-center flex-shrink-0">
          <svg aria-hidden="true" class="w-5 h-5 text-gov-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="{{ service.icon }}" clip-rule="evenodd"/></svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-navy mb-1">{{ service.title }}</h3>
          <p class="text-sm text-slate-600">{{ service.desc }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div>
    <h2 class="text-2xl font-bold text-navy mb-5">Upcoming Meetings</h2>
    <ul class="space-y-3">
      {% for meeting in events.meetings %}
      <li>
        <a href="{{ meeting.url }}" class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
          <div class="w-12 h-12 bg-navy text-white rounded-lg flex flex-col items-center justify-center flex-shrink-0 text-center leading-none">
            <span class="text-xs font-semibold opacity-70 uppercase">{{ meeting.month }}</span>
            <span class="text-lg font-bold">{{ meeting.day }}</span>
          </div>
          <div>
            <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">{{ meeting.title }}</div>
            <div class="text-xs text-slate-500 mt-0.5">{{ meeting.location }}</div>
          </div>
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>

  <div>
    <h2 class="text-2xl font-bold text-navy mb-5">Quick Links</h2>
    <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
      {% for link in [
        { label: "Meetings & Agendas", url: "/services/meetings/" },
        { label: "Public Records Request", url: "/services/public-records/" },
        { label: "Elections", url: "/services/elections/" },
        { label: "Council Minutes Archive", url: "https://www.aberdeenmd.gov/node/2090/minutes" },
        { label: "Frequently Requested Docs", url: "https://www.aberdeenmd.gov/city-clerk/pages/meetings" },
        { label: "Watch Live Meetings", url: "https://www.aberdeenmd.gov/city-clerk/pages/meetings" }
      ] %}
      <a href="{{ link.url | url }}" class="flex items-center justify-between gap-3 text-sm text-slate-700 font-medium px-5 py-3 hover:text-gov-blue hover:bg-slate-50 transition-colors duration-150 group border-b border-slate-100 last:border-b-0">
        {{ link.label }}
        <svg aria-hidden="true" class="w-4 h-4 text-slate-400 group-hover:text-gov-blue flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
      {% endfor %}
    </div>
  </div>
</div>
