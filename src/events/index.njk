---
layout: page.njk
title: Events & Meetings
subtitle: Community events, public meetings, and the full Aberdeen city calendar.
description: Upcoming community events and public meetings for the City of Aberdeen, Maryland.
breadcrumb:
  - label: Events
---

<div class="space-y-12">

  {# Two-column layout — Meetings + Community Events #}
  <div class="grid md:grid-cols-2 gap-10">

    {# ── Upcoming Meetings ── #}
    <div>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-navy flex items-center gap-3">
          <span class="w-1.5 h-8 bg-gov-blue rounded-full inline-block" aria-hidden="true"></span>
          Public Meetings
        </h2>
        <a href="https://www.aberdeenmd.gov/calendar-by-event-type/1370" class="text-sm text-gov-blue font-semibold hover:underline whitespace-nowrap">Full calendar →</a>
      </div>

      <div class="bg-gov-blue-light rounded-xl p-4 mb-4 text-sm text-slate-700">
        <strong>Public meetings are open to all residents.</strong> City Council meetings are streamed live. <a href="{{ '/services/meetings/' | url }}" class="text-gov-blue font-semibold hover:underline">Watch live or access agendas →</a>
      </div>

      <ul class="space-y-3" aria-label="Upcoming public meetings">
        {% for meeting in events.meetings %}
        <li>
          <a href="{{ meeting.url }}" class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
            <div class="w-14 h-14 bg-navy text-white rounded-lg flex flex-col items-center justify-center flex-shrink-0 text-center leading-none">
              <span class="text-xs font-semibold opacity-70 uppercase tracking-wide">{{ meeting.month }}</span>
              <span class="text-2xl font-bold">{{ meeting.day }}</span>
            </div>
            <div>
              <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">{{ meeting.title }}</div>
              <div class="text-xs text-slate-500 mt-1 flex items-center gap-1">
                <svg aria-hidden="true" class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
                {{ meeting.location }}
              </div>
            </div>
          </a>
        </li>
        {% endfor %}
      </ul>

      <div class="mt-6 space-y-3">
        <a href="{{ '/services/meetings/' | url }}" class="flex items-center gap-2 text-sm text-gov-blue font-semibold hover:underline">
          <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
          Agendas, minutes &amp; live stream
        </a>
        <a href="https://www.aberdeenmd.gov/calendar-by-event-type/1370" class="flex items-center gap-2 text-sm text-gov-blue font-semibold hover:underline">
          <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
          Full public meeting calendar
        </a>
      </div>
    </div>

    {# ── Community Events ── #}
    <div>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-navy flex items-center gap-3">
          <span class="w-1.5 h-8 bg-amber-500 rounded-full inline-block" aria-hidden="true"></span>
          Community Events
        </h2>
        <a href="https://www.aberdeenmd.gov/calendar-by-event-type/1367%2B1368%2B1369" class="text-sm text-gov-blue font-semibold hover:underline whitespace-nowrap">Full calendar →</a>
      </div>

      <ul class="space-y-3" aria-label="Upcoming community events">
        {% for event in events.community %}
        <li>
          <a href="{{ event.url }}" class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-4 hover:border-amber-400 hover:shadow-sm transition-all duration-200 group">
            <div class="w-14 h-14 bg-amber-500 text-white rounded-lg flex flex-col items-center justify-center flex-shrink-0 text-center leading-none">
              <span class="text-xs font-semibold opacity-80 uppercase tracking-wide">{{ event.month }}</span>
              <span class="text-2xl font-bold">{{ event.day }}</span>
            </div>
            <div>
              <div class="text-sm font-bold text-navy group-hover:text-amber-600 transition-colors duration-200">{{ event.title }}</div>
              <div class="text-xs text-slate-500 mt-1 flex items-center gap-1">
                <svg aria-hidden="true" class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
                {{ event.location }}
              </div>
            </div>
          </a>
        </li>
        {% endfor %}
      </ul>

      <div class="mt-6">
        <a href="https://www.aberdeenmd.gov/calendar-by-event-type/1367%2B1368%2B1369" class="flex items-center gap-2 text-sm text-gov-blue font-semibold hover:underline">
          <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
          Full community events calendar
        </a>
      </div>
    </div>

  </div>

  {# Aberdeen Main Street events highlight #}
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-5">
      <div>
        <h2 class="text-xl font-bold text-navy">Aberdeen Main Street Events</h2>
        <p class="text-sm text-slate-600 mt-1">Annual events celebrating Aberdeen's historic downtown and community spirit.</p>
      </div>
      <a href="{{ '/main-street/' | url }}" class="text-sm text-gov-blue font-semibold hover:underline whitespace-nowrap">About Main Street →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {% for event in [
        { title: "Mermaid 5K & Under the Sea Bash", month: "Jul", day: "19", url: "https://www.aberdeenmd.gov/aberdeen-main-street/main-street-events/events/41361" },
        { title: "Oktoberfest", month: "Oct", day: "4", url: "https://www.aberdeenmd.gov/aberdeen-main-street/main-street-events/events/41371" },
        { title: "Public Safety Appreciation & Trunk or Treat", month: "Oct", day: "25", url: "https://www.aberdeenmd.gov/aberdeen-main-street/main-street-events/events/41376" },
        { title: "49th Annual Christmas Street Celebration", month: "Dec", day: "6", url: "https://www.aberdeenmd.gov/aberdeen-main-street/main-street-events/events/41381" }
      ] %}
      <a href="{{ event.url }}" class="flex items-center gap-3 p-3 rounded-xl bg-slate-50 border border-slate-200 hover:border-amber-400 hover:shadow-sm transition-all duration-200 group">
        <div class="w-10 h-10 bg-amber-500 text-white rounded-lg flex flex-col items-center justify-center flex-shrink-0 text-center leading-none">
          <span class="text-xs font-semibold opacity-80 uppercase">{{ event.month }}</span>
          <span class="text-sm font-bold">{{ event.day }}</span>
        </div>
        <span class="text-xs font-semibold text-navy group-hover:text-amber-600 transition-colors duration-200 leading-snug">{{ event.title }}</span>
      </a>
      {% endfor %}
    </div>
  </div>

  {# Stay informed CTA #}
  <div class="grid sm:grid-cols-3 gap-4">
    <a href="{{ '/newsletter/' | url }}" class="flex flex-col items-center gap-3 bg-white border border-slate-200 rounded-xl p-6 hover:border-gov-blue hover:shadow-md transition-all duration-200 text-center group">
      <div class="w-10 h-10 rounded-full bg-gov-blue-light flex items-center justify-center group-hover:bg-gov-blue transition-colors duration-200">
        <svg aria-hidden="true" class="w-5 h-5 text-gov-blue group-hover:text-white transition-colors duration-200" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
      </div>
      <span class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">City Newsletter</span>
      <span class="text-xs text-slate-500">Events &amp; updates by email</span>
    </a>
    <a href="{{ '/emergency-alerts/' | url }}" class="flex flex-col items-center gap-3 bg-white border border-slate-200 rounded-xl p-6 hover:border-gov-blue hover:shadow-md transition-all duration-200 text-center group">
      <div class="w-10 h-10 rounded-full bg-gov-blue-light flex items-center justify-center group-hover:bg-gov-blue transition-colors duration-200">
        <svg aria-hidden="true" class="w-5 h-5 text-gov-blue group-hover:text-white transition-colors duration-200" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zm0 16a3 3 0 01-3-3h6a3 3 0 01-3 3z"/></svg>
      </div>
      <span class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">Emergency Alerts</span>
      <span class="text-xs text-slate-500">Calls &amp; texts for urgent notices</span>
    </a>
    <a href="{{ site.facebook }}" class="flex flex-col items-center gap-3 bg-white border border-slate-200 rounded-xl p-6 hover:border-gov-blue hover:shadow-md transition-all duration-200 text-center group">
      <div class="w-10 h-10 rounded-full bg-gov-blue-light flex items-center justify-center group-hover:bg-gov-blue transition-colors duration-200">
        <svg aria-hidden="true" class="w-5 h-5 text-gov-blue group-hover:text-white transition-colors duration-200" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </div>
      <span class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">Follow on Facebook</span>
      <span class="text-xs text-slate-500">@cityofaberdeenmd</span>
    </a>
  </div>

</div>
