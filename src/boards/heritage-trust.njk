<div class="grid lg:grid-cols-3 gap-10">
  <div class="lg:col-span-2 space-y-8">

    <p class="text-slate-600 leading-relaxed">The Aberdeen Heritage Trust Committee works to identify, document, preserve, and promote Aberdeen's historic resources, buildings, landscapes, and cultural traditions. The committee connects residents with Aberdeen's rich history and advocates for the preservation of significant historic assets.</p>

    <div>
      <h2 class="text-xl font-bold text-navy mb-4">Aberdeen 250</h2>
      <div class="bg-navy rounded-xl p-6 text-white">
        <h3 class="text-lg font-bold mb-2">Aberdeen 250 Anniversary Series</h3>
        <p class="text-slate-300 text-sm mb-4">The Heritage Trust Committee is organizing a special speaker series celebrating Aberdeen's 250th anniversary — exploring the history, people, and forces that shaped our city.</p>
        <div class="space-y-2">
          <div class="bg-white/10 rounded-lg p-3 text-sm">
            <div class="font-semibold">Aberdeen 250: The Forces That Shaped Us — Part 2</div>
            <div class="text-slate-300 text-xs mt-1">Ruth Peters presents Aberdeen history from the Civil War through the 20th Century</div>
          </div>
        </div>
        <a href="{{ '/news/' | url }}" class="inline-flex items-center gap-2 mt-4 bg-gov-blue text-white font-semibold px-4 py-2 rounded hover:bg-gov-blue-dark transition-colors duration-200 text-sm">View News &amp; Announcements</a>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-navy mb-4">Committee Focus Areas</h2>
      <ul class="space-y-2">
        {% for item in [
          "Survey and document Aberdeen's historic buildings and sites",
          "Promote heritage tourism and historic walking tours",
          "Support preservation of historic structures and landscapes",
          "Partner with schools and libraries on local history programs",
          "Coordinate with the Architectural Review Committee on historic districts",
          "Organize events celebrating Aberdeen's history and culture"
        ] %}
        <li class="flex items-start gap-3 text-sm text-slate-600">
          <svg aria-hidden="true" class="w-5 h-5 text-gov-blue flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {{ item }}
        </li>
        {% endfor %}
      </ul>
    </div>

    <div>
      <h2 class="text-xl font-bold text-navy mb-4">Upcoming Meeting</h2>
      {% for meeting in events.meetings %}
      {% if "Heritage" in meeting.title %}
      <a href="{{ meeting.url }}" class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue transition-all duration-200 group">
        <div class="w-14 h-14 bg-navy text-white rounded-lg flex flex-col items-center justify-center flex-shrink-0 text-center leading-none">
          <span class="text-xs font-semibold opacity-70 uppercase">{{ meeting.month }}</span>
          <span class="text-2xl font-bold">{{ meeting.day }}</span>
        </div>
        <div>
          <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">{{ meeting.title }}</div>
          <div class="text-xs text-slate-500 mt-1">{{ meeting.location }}</div>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>

  </div>

  <aside>
    <div class="bg-white border border-slate-200 rounded-xl p-6 sticky top-24 space-y-5">
      <h2 class="text-base font-bold text-navy pb-3 border-b border-slate-100">Contact</h2>
      <dl class="space-y-3 text-sm">
        <div><dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Phone</dt><dd><a href="tel:+14102721600" class="text-gov-blue hover:underline">(410) 272-1600</a></dd></div>
        <div><dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Meetings</dt><dd class="text-slate-700">Monthly — Council Chambers<br/>60 N. Parke Street</dd></div>
        <div><dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Hours</dt><dd class="text-slate-700">Mon–Fri, 8:30 AM – 5:00 PM</dd></div>
      </dl>
      <div class="pt-2 space-y-2">
        <a href="{{ '/boards/architectural-review/' | url }}" class="block w-full text-center bg-gov-blue text-white text-sm font-semibold py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200">Architectural Review</a>
        <a href="{{ '/news/' | url }}" class="block w-full text-center border border-slate-200 text-slate-700 text-sm font-semibold py-2.5 rounded hover:border-gov-blue hover:text-gov-blue transition-colors duration-200">City News</a>
      </div>
    </div>
  </aside>
</div>
