          <div class="font-semibold">Aberdeen Activity Center</div>
          <div class="text-blue-100">7 Franklin Street, Aberdeen, MD 21001</div>
        </div>
        <div>
          <div class="text-blue-200 text-xs font-semibold uppercase tracking-wide mb-1">Voting Hours</div>
          <div class="font-semibold">7:00 AM – 8:00 PM</div>
          <div class="text-blue-100">Two Council seats — 4-year terms</div>
        </div>
      </div>
    </div>

