---
layout: base.njk
---

{# ── PAGE HERO ── #}
<section class="bg-navy pb-8 border-b-4 border-gov-blue" aria-label="{{ title }}">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    {# Breadcrumb #}
    {% if breadcrumb %}
    <nav aria-label="Breadcrumb" class="mb-5">
      <ol class="flex items-center gap-2 text-sm text-slate-400">
        <li><a href="{{ '/' | url }}" class="hover:text-white transition-colors duration-200">Home</a></li>
        {% for crumb in breadcrumb %}
        <li aria-hidden="true" class="text-slate-600">/</li>
        {% if loop.last %}
        <li class="text-slate-300" aria-current="page">{{ crumb.label }}</li>
        {% else %}
        <li><a href="{{ crumb.url | url }}" class="hover:text-white transition-colors duration-200">{{ crumb.label }}</a></li>
        {% endif %}
        {% endfor %}
      </ol>
    </nav>
    {% endif %}

    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">{{ title }}</h1>
    {% if subtitle %}
    <p class="text-slate-300 text-lg max-w-2xl leading-relaxed">{{ subtitle }}</p>
    {% endif %}
  </div>
</section>

{# ── PAGE BODY ── #}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
  {{ content | safe }}
</div>
