---
layout: page.njk
title: Business Resources
subtitle: Everything you need to start, grow, or relocate a business in Aberdeen, Maryland.
description: Business resources for Aberdeen, Maryland — permits, incentives, bids, zoning, and economic development support.
breadcrumb:
  - label: Businesses
---

<div class="space-y-10">

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {% set bizLinks = [
      { title: "Business Incentives & Funding", desc: "State and local grants, tax credits, and financing programs for Aberdeen businesses.", url: "/businesses/incentives/", icon: "star" },
      { title: "How to Apply for a Permit", desc: "Building permits, zoning approvals, and business licenses for your project.", url: "/businesses/permits/", icon: "doc" },
      { title: "Bids & RFPs", desc: "Current procurement opportunities and requests for proposals from the City.", url: "/businesses/bids/", icon: "bid" },
      { title: "Zoning Appeals", desc: "Request a variance or special exception through the Board of Appeals.", url: "/boards/board-of-appeals/", icon: "map" },
      { title: "Planning Commission", desc: "Site plan review, rezoning requests, and development approvals.", url: "/boards/planning-commission/", icon: "plan" },
      { title: "Transit-Oriented Development", desc: "Aberdeen's TOD plan for mixed-use development around the MARC station.", url: "/businesses/tod-plan/", icon: "train" }
    ] %}
    {% for item in bizLinks %}
    <a href="{{ item.url | url }}" class="flex flex-col bg-white border border-slate-200 rounded-xl p-5 hover:border-gov-blue hover:shadow-md transition-all duration-200 group">
      <div class="w-9 h-9 rounded-lg bg-gov-blue-light flex items-center justify-center mb-3 group-hover:bg-gov-blue transition-colors duration-200" aria-hidden="true">
        <svg class="w-5 h-5 text-gov-blue group-hover:text-white transition-colors duration-200" fill="currentColor" viewBox="0 0 20 20">
          {% if item.icon == "star" %}<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          {% elif item.icon == "doc" %}<path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
          {% elif item.icon == "bid" %}<path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm2 10a1 1 0 10-2 0v3a1 1 0 102 0v-3zm2-3a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm4-1a1 1 0 10-2 0v7a1 1 0 102 0V8z" clip-rule="evenodd"/>
          {% elif item.icon == "map" %}<path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          {% elif item.icon == "plan" %}<path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
          {% else %}<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 0l-3 3a1 1 0 001.414 1.414L9 9.414V13a1 1 0 102 0V9.414l1.293 1.293a1 1 0 001.414-1.414z" clip-rule="evenodd"/>
          {% endif %}
        </svg>
      </div>
      <h2 class="text-sm font-bold text-navy mb-2 group-hover:text-gov-blue transition-colors duration-200">{{ item.title }}</h2>
      <p class="text-xs text-slate-600 leading-relaxed">{{ item.desc }}</p>
    </a>
    {% endfor %}
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-navy rounded-xl p-6 text-white">
      <h2 class="text-xl font-bold mb-3">Why Aberdeen?</h2>
      <ul class="space-y-2 text-sm text-slate-300">
        {% for fact in ["Prime Mid-Atlantic location — I-95 corridor", "MARC commuter rail directly to Baltimore & DC", "Home of Aberdeen Proving Ground (APG)", "World-class Harford County Public Schools", "Growing workforce and residential base", "Competitive incentive programs available"] %}
        <li class="flex items-start gap-2">
          <svg aria-hidden="true" class="w-4 h-4 text-gov-blue flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {{ fact }}
        </li>
        {% endfor %}
      </ul>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-6 flex flex-col justify-between">
      <div>
        <h2 class="text-xl font-bold text-navy mb-3">Aberdeen Chamber of Commerce</h2>
        <p class="text-sm text-slate-600 mb-4">Connect with the local business community, networking events, and advocacy through the Aberdeen Chamber of Commerce.</p>
      </div>
      <div class="space-y-3">
        <a href="https://www.aberdeenchamber.org" class="block w-full text-center bg-gov-blue text-white font-semibold py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200 text-sm">Visit Chamber Website</a>
        <a href="{{ '/departments/economic-development/' | url }}" class="block w-full text-center border border-slate-200 text-slate-700 font-semibold py-2.5 rounded hover:border-gov-blue hover:text-gov-blue transition-colors duration-200 text-sm">Economic Development Dept.</a>
      </div>
    </div>
  </div>

</div>
