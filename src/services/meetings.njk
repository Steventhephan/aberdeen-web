---
layout: page.njk
title: Meetings & Legislation
subtitle: Council meeting agendas, minutes, live streaming, and the full public meeting calendar.
description: View Aberdeen city council meeting agendas, minutes, watch live streams, and find the public meeting calendar.
breadcrumb:
  - label: Services
    url: /#services
  - label: Meetings
---

<div class="grid lg:grid-cols-3 gap-10">
  <div class="lg:col-span-2 space-y-10">

    {# Watch Live #}
    <div class="bg-navy rounded-xl p-6 text-white">
      <div class="flex items-center gap-3 mb-3">
        <span class="flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-3 w-3 rounded-full bg-red-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
        </span>
        <span class="text-red-400 text-xs font-semibold uppercase tracking-widest">Live</span>
      </div>
      <h2 class="text-xl font-bold mb-2">Watch Council Meetings Live</h2>
      <p class="text-slate-300 text-sm mb-4">Council meetings are streamed live. Click "IN PROGRESS" during a meeting to watch or listen.</p>
      <a href="https://www.aberdeenmd.gov/city-clerk/pages/meetings" class="inline-flex items-center gap-2 bg-gov-blue text-white font-semibold px-5 py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200 text-sm">
        Open Live Meeting Portal
      </a>
    </div>

    {# Upcoming Meetings #}
    <div>
      <h2 class="text-2xl font-bold text-navy mb-6">Upcoming Meetings</h2>
      <ul class="space-y-3">
        {% for meeting in events.meetings %}
        <li>
          <a href="{{ meeting.url }}" class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 cursor-pointer group">
            <div class="w-14 h-14 bg-navy text-white rounded-lg flex flex-col items-center justify-center flex-shrink-0 text-center leading-none">
              <span class="text-xs font-semibold opacity-70 uppercase">{{ meeting.month }}</span>
              <span class="text-xl font-bold">{{ meeting.day }}</span>
            </div>
            <div>
              <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">{{ meeting.title }}</div>
              <div class="text-xs text-slate-500 mt-1">{{ meeting.location }}</div>
            </div>
          </a>
        </li>
        {% endfor %}
      </ul>
      <div class="mt-4">
        <a href="https://www.aberdeenmd.gov/calendar-by-event-type/1370" class="text-gov-blue font-semibold hover:underline text-sm">View full meeting calendar →</a>
      </div>
    </div>

    {# Documents #}
    <div>
      <h2 class="text-2xl font-bold text-navy mb-6">Agendas, Minutes &amp; Documents</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="https://www.aberdeenmd.gov/node/2090/agenda" class="flex items-center gap-3 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
          <svg aria-hidden="true" class="w-8 h-8 text-gov-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
          <div>
            <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">Council Agendas</div>
            <div class="text-xs text-slate-500">Current &amp; upcoming agendas</div>
          </div>
        </a>
        <a href="https://www.aberdeenmd.gov/node/2090/minutes" class="flex items-center gap-3 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
          <svg aria-hidden="true" class="w-8 h-8 text-gov-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
          <div>
            <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">Council Minutes</div>
            <div class="text-xs text-slate-500">Official meeting minutes archive</div>
          </div>
        </a>
        <a href="https://www.aberdeenmd.gov/city-clerk/pages/meetings" class="flex items-center gap-3 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
          <svg aria-hidden="true" class="w-8 h-8 text-gov-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
          <div>
            <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">Meeting Calendar 2026</div>
            <div class="text-xs text-slate-500">Full year schedule</div>
          </div>
        </a>
        <a href="https://www.aberdeenmd.gov/city-clerk/pages/meetings" class="flex items-center gap-3 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
          <svg aria-hidden="true" class="w-8 h-8 text-gov-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.586L7.707 9.293a1 1 0 00-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 10.586V7z" clip-rule="evenodd"/></svg>
          <div>
            <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">Council Rules of Procedure</div>
            <div class="text-xs text-slate-500">Governing rules document</div>
          </div>
        </a>
      </div>
    </div>

  </div>

  <aside>
    <div class="bg-white border border-slate-200 rounded-xl p-6 sticky top-24 space-y-6">
      <div>
        <h2 class="text-base font-bold text-navy mb-3 pb-3 border-b border-slate-100">City Clerk</h2>
        <dl class="space-y-3 text-sm">
          <div>
            <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Phone</dt>
            <dd><a href="tel:+14102721600" class="text-gov-blue hover:underline">(410) 272-1600 ext. 211</a></dd>
          </div>
          <div>
            <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Fax</dt>
            <dd class="text-slate-700">(410) 273-7402</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Hours</dt>
