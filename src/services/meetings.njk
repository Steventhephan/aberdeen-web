---
layout: page.njk
title: Meetings & Legislation
subtitle: Council meeting agendas, minutes, live streaming, and the full public meeting calendar.
description: View Aberdeen city council meeting agendas, minutes, watch live streams, and find the public meeting calendar.
breadcrumb:
  - label: Services
    url: /#services
  - label: Meetings
---

<div class="grid lg:grid-cols-3 gap-12">
  <div class="lg:col-span-2 space-y-10">

    <div class="bg-navy rounded-xl p-6 text-white">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-2 h-2 rounded-full bg-red-400 inline-block" aria-hidden="true"></span>
        <span class="text-red-400 text-xs font-semibold uppercase tracking-widest">Live Streaming Available</span>
      </div>
      <h2 class="text-xl font-bold mb-2">Watch Council Meetings</h2>
      <p class="text-slate-300 text-sm mb-4 leading-relaxed">Council meetings are streamed live on the city website. Click "IN PROGRESS" during a meeting to watch or listen.</p>
      <a href="https://www.aberdeenmd.gov/city-clerk/pages/meetings" class="inline-flex items-center gap-2 bg-gov-blue text-white font-semibold px-5 py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200 text-sm">
        Open Live Meeting Portal
      </a>
    </div>

    <div>
      <h2 class="text-xl font-bold text-navy mb-5">Upcoming Meetings</h2>
      <ul class="space-y-3" aria-label="Upcoming public meetings">
        {% for meeting in events.meetings %}
        <li>
          <a href="{{ meeting.url }}" class="flex items-center gap-4 bg-white border border-slate-200 rounded-xl p-4 hover:border-gov-blue hover:shadow-sm transition-all duration-200 group">
            <div class="w-14 h-14 bg-navy text-white rounded-lg flex flex-col items-center justify-center flex-shrink-0 text-center leading-none">
              <span class="text-xs font-semibold opacity-70 uppercase">{{ meeting.month }}</span>
              <span class="text-xl font-bold">{{ meeting.day }}</span>
            </div>
            <div>
              <div class="text-sm font-bold text-navy group-hover:text-gov-blue transition-colors duration-200">{{ meeting.title }}</div>
              <div class="text-xs text-slate-500 mt-1">{{ meeting.location }}</div>
            </div>
          </a>
        </li>
        {% endfor %}
      </ul>
      <div class="mt-4">
        <a href="https://www.aberdeenmd.gov/calendar-by-event-type/1370" class="text-gov-blue font-semibold hover:underline text-sm">View full meeting calendar →</a>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-navy mb-5">Agendas, Minutes &amp; Documents</h2>
      <div class="bg-white border border-slate-200 rounded-xl overflow-hidden divide-y divide-slate-100">
        {% for link in [
          { label: "Council Agendas", sub: "Current & upcoming meeting agendas", url: "https://www.aberdeenmd.gov/node/2090/agenda" },
          { label: "Council Minutes", sub: "Official meeting minutes archive", url: "https://www.aberdeenmd.gov/node/2090/minutes" },
          { label: "Meeting Calendar 2026", sub: "Full year schedule", url: "https://www.aberdeenmd.gov/city-clerk/pages/meetings" },
          { label: "Council Rules of Procedure", sub: "Governing rules document", url: "https://www.aberdeenmd.gov/city-clerk/pages/meetings" }
        ] %}
        <a href="{{ link.url }}" class="flex items-center justify-between gap-4 px-5 py-4 hover:bg-slate-50 transition-colors duration-150 group">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-gov-blue-light flex items-center justify-center flex-shrink-0 group-hover:bg-gov-blue transition-colors duration-150">
              <svg aria-hidden="true" class="w-4 h-4 text-gov-blue group-hover:text-white transition-colors duration-150" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <div class="text-sm font-semibold text-navy group-hover:text-gov-blue transition-colors duration-150">{{ link.label }}</div>
              <div class="text-xs text-slate-500 mt-0.5">{{ link.sub }}</div>
            </div>
          </div>
          <svg aria-hidden="true" class="w-4 h-4 text-slate-400 group-hover:text-gov-blue flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
        {% endfor %}
      </div>
    </div>

  </div>

  <aside>
    <div class="bg-white border border-slate-200 rounded-xl p-6 sticky top-24 space-y-5">
      <h2 class="text-base font-bold text-navy pb-3 border-b border-slate-100">City Clerk</h2>
      <dl class="space-y-4 text-sm">
        <div><dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Phone</dt><dd><a href="tel:+14102721600" class="text-gov-blue hover:underline">(410) 272-1600 ext. 211</a></dd></div>
        <div><dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Fax</dt><dd class="text-slate-700">(410) 273-7402</dd></div>
        <div><dt class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Hours</dt><dd class="text-slate-700">Mon–Fri, 8:30 AM – 5:00 PM</dd></div>
      </dl>
      <div class="pt-2 space-y-2">
        <a href="{{ '/departments/city-clerk/' | url }}" class="block w-full text-center bg-gov-blue text-white text-sm font-semibold py-2.5 rounded hover:bg-gov-blue-dark transition-colors duration-200">City Clerk Dept.</a>
        <a href="{{ '/services/public-records/' | url }}" class="block w-full text-center border border-slate-200 text-slate-700 text-sm font-semibold py-2.5 rounded hover:border-gov-blue hover:text-gov-blue transition-colors duration-200">Public Records</a>
      </div>
    </div>
  </aside>
</div>
