          <li><a href="{{ '/businesses/bids/' | url }}" class="text-gov-blue hover:underline">Bids &amp; RFPs</a></li>
          <li><a href="{{ '/contact/' | url }}" class="text-gov-blue hover:underline">Contact Directory</a></li>
