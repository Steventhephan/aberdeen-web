{
  "name": "aberdeen-web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i src/assets/input.css -o _site/assets/style.css --minify",
    "build:11ty": "eleventy",
    "build": "mkdir -p _site/assets && npm run build:css && npm run build:11ty",
    "dev:css": "tailwindcss -i src/assets/input.css -o _site/assets/style.css --watch",
    "dev:11ty": "eleventy --serve",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:11ty\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Steventhephan/aberdeen-web.git"
  },
